<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
            android:id="@+id/headerFull"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4CAF50"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"
            android:orientation="vertical">

        <!-- Row: back button + source chip + priority chip -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

            <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingEnd="16dp" />

            <TextView
                    android:id="@+id/tvFullSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/chip_source_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            <TextView
                    android:id="@+id/tvFullPriorityChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="🚨 URGENT"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/chip_urgent_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:visibility="gone" />

        </LinearLayout>

        <!-- Title -->
        <TextView
                android:id="@+id/tvFullTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification Title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

        <!-- Timestamp -->
        <TextView
                android:id="@+id/tvFullTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Today at 10:30 AM"
                android:textSize="12sp"
                android:textColor="#E8F5E9"
                android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Scrollable message body -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

            <!-- Accent card wrapping the message -->
            <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <!-- Left accent bar -->
                    <View
                            android:id="@+id/viewFullAccentBar"
                            android:layout_width="5dp"
                            android:layout_height="match_parent"
                            android:background="#4CAF50" />

                    <TextView
                            android:id="@+id/tvFullMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Full message body..."
                            android:textSize="16sp"
                            android:textColor="#222222"
                            android:lineSpacingMultiplier="1.6"
                            android:padding="16dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>