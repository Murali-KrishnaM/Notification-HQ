<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_deep">

    <!-- Top glow line -->
    <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="@drawable/glow_line_green"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════  HEADER  ══════════════════ -->
    <LinearLayout
            android:id="@+id/headerFull"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/header_glass_bg"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="22dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <!-- Row: back + chips -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

            <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp"
                    android:fontFamily="@font/mono_font"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                    android:id="@+id/tvFullSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/chip_source_dark"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            <TextView
                    android:id="@+id/tvFullPriorityChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="🔴 URGENT"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/chip_urgent_dark"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone" />

        </LinearLayout>

        <!-- Title -->
        <TextView
                android:id="@+id/tvFullTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification Title"
                android:textSize="22sp"
                android:fontFamily="@font/display_font"
                android:textColor="@color/text_primary" />

        <!-- Timestamp -->
        <TextView
                android:id="@+id/tvFullTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Today at 10:30 AM"
                android:textSize="12sp"
                android:fontFamily="@font/mono_font"
                android:textColor="@color/text_hint"
                android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Separator -->
    <View
            android:id="@+id/headerDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            app:layout_constraintTop_toBottomOf="@id/headerFull"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════  SCROLLABLE BODY  ══════════════════ -->
    <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/headerDivider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="100dp"> <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <View
                        android:id="@+id/viewFullAccentBar"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_green" />

                <TextView
                        android:id="@+id/tvFullMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full message body..."
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.7"
                        android:padding="20dp"
                        android:fontFamily="sans-serif-light" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

            <TextView
                    android:id="@+id/btnSummarize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="✦ Summarize with AI"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textColor="@color/accent_green"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/mono_font" />

            <androidx.cardview.widget.CardView
                    android:id="@+id/cardSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦ AI Summary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="@color/accent_green"
                            android:fontFamily="@font/mono_font"
                            android:layout_marginBottom="10dp" />

                    <ProgressBar
                            android:id="@+id/progressSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:visibility="gone" />

                    <TextView
                            android:id="@+id/tvSummaryText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.6"
                            android:fontFamily="sans-serif-light"
                            android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>