<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/dialog_bg">

        <!-- Header row: icon + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="＋"
                android:textSize="20sp"
                android:textColor="@color/bg_deep"
                android:background="@drawable/icon_circle_green"
                android:layout_marginEnd="14dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD NEW COURSE"
                    android:textColor="@color/accent_green"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="@font/mono_font" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course Setup"
                    android:textSize="20sp"
                    android:fontFamily="@font/display_font"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Subtle horizontal rule -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp" />

        <!-- Course Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCourseName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="Course Name *"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/accent_green"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCourseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapWords"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Course Symbol -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCourseSymbol"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="Course Symbol * (e.g., NLPA)"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/accent_green"
            app:counterEnabled="true"
            app:counterMaxLength="8"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCourseSymbol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapCharacters"
                android:maxLength="8"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Course ID -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCourseId"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Course ID * (e.g., AD23B32)"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/accent_green"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCourseId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapCharacters"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  OPTIONAL CHANNEL LINKS  "
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.12"
                android:fontFamily="@font/mono_font" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

        </LinearLayout>

        <!-- Faculty Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFacultyName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="Faculty Name"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFacultyName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPersonName"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- WhatsApp Group -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilWhatsappGroup"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="WhatsApp Group Name"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWhatsappGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Google Classroom -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilClassroomName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Google Classroom Name"
            app:boxStrokeColor="@color/accent_green"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etClassroomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
