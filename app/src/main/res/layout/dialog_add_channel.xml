<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/dialog_bg">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="＋"
                android:textSize="20sp"
                android:textColor="@color/bg_deep"
                android:background="@drawable/icon_circle_blue"
                android:layout_marginEnd="14dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLACEMENTS"
                    android:textColor="@color/accent_blue"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="@font/mono_font" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Channel"
                    android:textSize="20sp"
                    android:fontFamily="@font/display_font"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect a WhatsApp group or email to automatically capture placement updates."
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp" />

        <!-- Channel Label -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilChannelLabel"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="Channel Label * (e.g. Placement Cell)"
            app:boxStrokeColor="@color/accent_blue"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/accent_blue"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etChannelLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapWords"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  CONNECT CHANNELS (AT LEAST ONE)  "
                android:textSize="9sp"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.1"
                android:fontFamily="@font/mono_font" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider_color" />

        </LinearLayout>

        <!-- WhatsApp Group -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlacementWaGroup"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:hint="WhatsApp Group Name (optional)"
            app:boxStrokeColor="@color/accent_blue"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlacementWaGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email addresses -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlacementEmails"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Sender Name(s) Comma seperated"
            app:boxStrokeColor="@color/accent_blue"
            app:boxBackgroundColor="@color/input_bg"
            app:hintTextColor="@color/text_muted"
            app:helperText="e.g. Placement REC Exe1"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlacementEmails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textEmailAddress|textMultiLine"
                android:minLines="2"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
