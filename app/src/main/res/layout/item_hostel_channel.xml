<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hostel_channel.xml
    ════════════════════════════════════════════════════════════════════════
    BUG FIX: The previous file was a completely empty ConstraintLayout with
    no child views and no IDs.  Any adapter that inflated it and called
    findViewById() would receive null, crashing immediately with an NPE.

    This layout mirrors item_placement_channel.xml so that a Hostel channel
    adapter can safely inflate and bind it.  The accent bar is tinted
    distinctively (deep teal) so Hostel rows are visually distinct from
    Placement (amber) rows at a glance.

    Required IDs (must match what the adapter looks up):
      • viewChannelAccent      — coloured left bar
      • tvChannelLabel         — channel name
      • tvChannelNotifCount    — badge (hidden when count == 0)
      • tvEmailAddresses       — associated email(s), one per line
      • rowWaGroup             — WhatsApp group row container
      • tvWaGroupName          — WA group name text inside rowWaGroup
-->
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="6dp"
        android:background="?attr/colorSurface"
        android:elevation="2dp"
        android:minHeight="72dp">

    <!-- Coloured accent bar on the left edge (teal for Hostel) -->
    <View
            android:id="@+id/viewChannelAccent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#FF00897B"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- Channel label (course / hostel block name) -->
    <TextView
            android:id="@+id/tvChannelLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintEnd_toStartOf="@id/tvChannelNotifCount"
            app:layout_constraintStart_toEndOf="@id/viewChannelAccent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- Notification count badge (GONE when count == 0) -->
    <TextView
            android:id="@+id/tvChannelNotifCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/badge_bg"
            android:minWidth="24dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvChannelLabel" />

    <!-- Associated email addresses (one per line, GONE when blank) -->
    <TextView
            android:id="@+id/tvEmailAddresses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewChannelAccent"
            app:layout_constraintTop_toBottomOf="@id/tvChannelLabel" />

    <!-- WhatsApp group row (GONE for channels that have no WA group) -->
    <LinearLayout
            android:id="@+id/rowWaGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewChannelAccent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailAddresses">

        <TextView
                android:id="@+id/tvWaGroupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="4dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>