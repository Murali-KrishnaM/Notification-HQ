<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F5F5F5">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F57F17"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="20dp"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NPTEL / SWAYAM"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track your online course deadlines"
                    android:textColor="#FFF8E1"
                    android:textSize="14sp" />

        </LinearLayout>

        <!-- Channel list -->
        <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewNptelChannels"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="8dp"
                    android:paddingBottom="80dp" />

            <!-- Empty state -->
            <LinearLayout
                    android:id="@+id/layoutNptelEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="80dp"
                    android:visibility="gone">

                <ImageView
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:alpha="0.25" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="No NPTEL courses yet"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#9E9E9E" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tap ＋ to add an NPTEL course email"
                        android:textSize="14sp"
                        android:textColor="#BDBDBD"
                        android:gravity="center" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddNptelChannel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="24dp"
            android:backgroundTint="#F57F17"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Add NPTEL Course"
            app:tint="#FFFFFF" />

</RelativeLayout>