<?xml version="1.0" encoding="utf-8"?>
<!--
    item_subject.xml
    Dark glass card for each subject/course in the Academics tab.
    Accent color on the symbol pill is set dynamically by the adapter.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSubject"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_bg">

    <!-- Left neon accent bar — width 3dp, color set by adapter -->
    <View
        android:id="@+id/viewSubjectAccent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/accent_green" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Colored symbol pill -->
        <TextView
            android:id="@+id/tvSubjectSymbol"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="CS"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:textColor="@color/bg_deep"
            android:background="@drawable/subject_symbol_bg" />

        <!-- Name + course ID -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvSubjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject Name"
                android:textSize="16sp"
                android:fontFamily="@font/display_font"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCourseId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AD23B32"
                android:textSize="11sp"
                android:fontFamily="@font/mono_font"
                android:textColor="@color/text_hint"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <!-- Notification count badge -->
        <TextView
            android:id="@+id/tvNotifCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/bg_deep"
            android:background="@drawable/badge_bg"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:minWidth="28dp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
