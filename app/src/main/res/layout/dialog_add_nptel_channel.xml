<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#FFFFFF">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add NPTEL Course"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F57F17"
                android:layout_marginBottom="6dp" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add the course name and the sender email address from your NPTEL/SWAYAM emails so we can automatically capture deadline updates."
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="20dp" />

        <!-- Course Label -->
        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNptelLabel"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Course Name * (e.g. Cloud Computing)"
                app:boxStrokeColor="#F57F17"
                app:hintTextColor="#F57F17"
                app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNptelLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email addresses -->
        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNptelEmails"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:hint="Sender Email(s) (comma separated)"
                app:boxStrokeColor="#F57F17"
                app:hintTextColor="#F57F17"
                app:helperText="e.g. no-reply@nptel.iitm.ac.in"
                app:helperTextEnabled="true"
                app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNptelEmails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress|textMultiLine"
                    android:minLines="2"
                    android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>