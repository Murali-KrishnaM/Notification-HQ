<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_bg">

    <!-- Blue accent bar for placements -->
    <View
        android:id="@+id/viewChannelAccent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/accent_blue" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Row 1: label + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChannelLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Placement Cell"
                android:fontFamily="@font/display_font"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvChannelNotifCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/bg_deep"
                android:background="@drawable/badge_blue_bg"
                android:paddingStart="9dp"
                android:paddingEnd="9dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:minWidth="28dp"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Row 2: WhatsApp group chip -->
        <LinearLayout
            android:id="@+id/rowWaGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:background="@drawable/chip_source_dark"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/tvWaGroupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Group Name"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Row 3: Email addresses -->
        <TextView
            android:id="@+id/tvEmailAddresses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="email@domain.com"
            android:textSize="12sp"
            android:fontFamily="@font/mono_font"
            android:textColor="@color/text_hint"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
