<?xml version="1.0" encoding="utf-8"?>
<!--
    header_glass_bg.xml
    The frosted-glass header panel for Academics / Detail screens.
    Deep dark base with a very subtle green tint in the gradient.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0F14" />
        </shape>
    </item>

    <!-- Subtle green-tinted overlay gradient to create depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                    android:type="linear"
                    android:startColor="#1200E5A0"
                    android:endColor="#00000000"
                    android:angle="270" />
        </shape>
    </item>

    <!-- Bottom border glow line (very subtle) -->
    <item
            android:top="-2dp"
            android:left="-2dp"
            android:right="-2dp">
        <shape android:shape="rectangle">
            <stroke
                    android:width="1dp"
                    android:color="#1A00E5A0" />
        </shape>
    </item>

</layer-list>