<?xml version="1.0" encoding="utf-8"?>
<!-- dashboard_stat_bg.xml — frosted glass card for the stats row -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#161A23" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#1EFFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>