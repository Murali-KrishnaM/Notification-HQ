<?xml version="1.0" encoding="utf-8"?>
<!--
    chip_due_dark.xml
    Replaces old chip_due_bg (#F57F17 solid).
    Dark amber base with glowing border for NPTEL deadline chips.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2E1E00" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#CCFFB340" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
