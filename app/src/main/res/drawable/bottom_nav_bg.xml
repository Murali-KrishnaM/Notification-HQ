    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0F14" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#1EFFFFFF" />
        </shape>
    </item>
</layer-list>