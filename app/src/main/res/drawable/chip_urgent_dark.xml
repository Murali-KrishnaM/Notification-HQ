<?xml version="1.0" encoding="utf-8"?>
<!--
    chip_urgent_dark.xml
    Replaces old solid-red chip_urgent_bg.
    Neon red with a slight glow border for the futuristic look.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3D0011" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#CCFF4D6A" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
