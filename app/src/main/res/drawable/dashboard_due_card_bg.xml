<?xml version="1.0" encoding="utf-8"?>
<!-- dashboard_due_card_bg.xml — amber tinted glass for the next-due card -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1600" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                    android:type="linear"
                    android:startColor="#22FFB340"
                    android:endColor="#00000000"
                    android:angle="135" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#40FFB340" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>