<?xml version="1.0" encoding="utf-8"?>
<!--
    header_glass_amber_bg.xml
    Header panel for NPTEL — subtle amber tint.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0F14" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                    android:type="linear"
                    android:startColor="#1AFFB340"
                    android:endColor="#00000000"
                    android:angle="270" />
        </shape>
    </item>

    <item
            android:top="-2dp"
            android:left="-2dp"
            android:right="-2dp">
        <shape android:shape="rectangle">
            <stroke
                    android:width="1dp"
                    android:color="#1AFFB340" />
        </shape>
    </item>

</layer-list>