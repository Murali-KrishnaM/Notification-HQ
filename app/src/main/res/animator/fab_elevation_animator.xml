<?xml version="1.0" encoding="utf-8"?>
<!--
    fab_elevation_animator.xml
    Place in res/animator/
    Gives the FAB a satisfying "press in" elevation drop on touch.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed: drop elevation, scale down slightly -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="100"
                android:valueTo="2dp"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="100"
                android:valueTo="0.95"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="100"
                android:valueTo="0.95"
                android:valueType="floatType" />
        </set>
    </item>

    <!-- Default: restore elevation and scale -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="200"
                android:valueTo="6dp"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="200"
                android:valueTo="1.0"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="200"
                android:valueTo="1.0"
                android:valueType="floatType" />
        </set>
    </item>

</selector>
