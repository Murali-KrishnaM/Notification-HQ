<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NotificationHQ" parent="Theme.Material3.Dark.NoActionBar">

        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorOnPrimary">@color/bg_deep</item>
        <item name="colorPrimaryContainer">#1A3D2E</item>
        <item name="colorOnPrimaryContainer">@color/accent_green</item>

        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/bg_deep</item>

        <item name="colorTertiary">@color/accent_amber</item>
        <item name="colorOnTertiary">@color/bg_deep</item>

        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">#FFFFFF</item>

        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">#1C2030</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>

        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="colorOutline">@color/divider_color</item>

        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>

        <item name="floatingActionButtonStyle">@style/FAB.NotificationHQ</item>

        <item name="tabStyle">@style/TabStyle.NotificationHQ</item>

    </style>

    <style name="FAB.NotificationHQ" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent_green</item>
        <item name="tint">@color/bg_deep</item>
        <item name="elevation">12dp</item>
        <item name="android:stateListAnimator">@animator/fab_elevation_animator</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="TabStyle.NotificationHQ" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorAnimationMode">elastic</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabIndicatorColor">@color/accent_green</item>
        <item name="tabSelectedTextColor">@color/accent_green</item>
        <item name="tabTextColor">@color/text_muted</item>
        <item name="tabRippleColor">@color/ripple_green</item>
    </style>

    <style name="DialogTheme.NotificationHQ" parent="ThemeOverlay.Material3.MaterialAlertDialog.Centered">
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@drawable/dialog_bg</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogButton.Green</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButton.Ghost</item>
    </style>

    <style name="DialogButton.Green" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:textColor">@color/bg_deep</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="DialogButton.Ghost" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_muted</item>
    </style>

</resources>